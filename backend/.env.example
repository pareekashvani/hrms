# Copy this file to `.env` in the same folder (backend/) and edit values there.
# Never commit real `.env` files (they are gitignored).

SECRET_KEY=replace-with-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=sqlite:///./hrms.db
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/hrms

DEFAULT_ADMIN_EMAIL=admin@gmail.com
DEFAULT_ADMIN_PASSWORD=admin123

# Employee attendance geofence (optional fallback): set BOTH latitude and longitude to enable
# when no location has been saved from the admin dashboard (POST /admin/set-admin-location).
# ADMIN_LOCATION_LATITUDE=
# ADMIN_LOCATION_LONGITUDE=
# ATTENDANCE_GEOFENCE_RADIUS_METERS=20
#
# Legacy variable names still work: ATTENDANCE_OFFICE_LATITUDE / ATTENDANCE_OFFICE_LONGITUDE
